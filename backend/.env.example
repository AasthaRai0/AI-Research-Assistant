# Copy this file to .env and fill in real values before running the app.

# --- General ---
APP_NAME=AI Research Assistant API
ENVIRONMENT=development
DEBUG=true

# --- Security ---
# Generate a strong secret: `openssl rand -hex 32`
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Database ---
# Format: postgresql+psycopg2://<user>:<password>@<host>:<port>/<db_name>
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/research_assistant

# --- CORS (comma-separated list is parsed as JSON array by pydantic-settings,
# so keep the brackets) ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- File uploads ---
UPLOAD_DIR=storage/uploads
MAX_UPLOAD_SIZE_MB=25

# --- RAG / AI ---
OPENAI_API_KEY=sk-your-openai-api-key
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Vector store ---
CHROMA_PERSIST_DIR=storage/chroma

# --- Chunking / retrieval ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
RETRIEVAL_TOP_K=4
